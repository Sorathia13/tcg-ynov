# --- Base de données (PostgreSQL / Prisma) ---
# Correspond au docker-compose.yml fourni à la racine.
DATABASE_URL="postgresql://tcg:tcg@localhost:5432/tcg?schema=public"

# --- Serveur HTTP ---
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"

# --- Authentification (JWT) ---
JWT_SECRET="change-me-in-production-please"
JWT_EXPIRES_IN="2h"

# --- IA (Ollama) ---
# Ollama doit tourner en local : https://ollama.com/download
# puis : ollama pull llama3.2
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"
# Délai max (ms) laissé au LLM pour répondre avant repli de sécurité
OLLAMA_TIMEOUT_MS=20000
